# =============================================================================
# Setup locale LPFT API
# -----------------------------------------------------------------------------
# 1. Copia questo file come .env.local (stessa cartella services/api):
#       cp env.local.template .env.local
# =============================================================================

LPFT_ANTHROPIC_API_KEY=

LPFT_FRONTEND_BASE_URL=http://localhost:3000

# --- Database LPFT (PostgreSQL) ---
# Stesso host/cluster di AFX (Prisma), database LOGICO separato consigliato: `lpft` vs `afx_dev`.
# Avvio rapido: `cd infra && docker compose up -d postgres` (user/pass/db: lpft/lpft/lpft).
# Legacy SQLite ancora supportato se imposti esplicitamente sqlite:///...
LPFT_DATABASE_URL=postgresql+psycopg://lpft:lpft@127.0.0.1:5432/lpft
LPFT_REDIS_URL=redis://localhost:6379/0

# --- Ponte event-driven LPFT → AFX (Redis) ---
# Abilita publish dopo generazione strategia; consumer: `cd apps/web && npm run worker:intents` (stesso Redis: LPFT_REDIS_URL / REDIS_URL, stesso channel)
LPFT_AFX_INTENTS_ENABLED=false
LPFT_AFX_INTENTS_CHANNEL=afx:intents:new
