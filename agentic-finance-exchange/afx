#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

usage() {
  sed -n '1,100p' <<'EOF'
AFX — comandi dalla root del pacchetto

Uso:
  ./afx <comando>

Comandi:
  install       npm install (rigenera Prisma al postinstall)
  dev           avvia Next su http://localhost:3001
  dev-clean     rimuove .next, libera porta 3001, poi dev
  clean         rimuove solo le cartelle .next (fix chunk mancanti)
  build         build di produzione web
  start         next start (dopo build)
  lint          eslint sull’app web

  prisma-gen    npx prisma generate
  migrate       npx prisma migrate dev
  deploy        npx prisma migrate deploy
  studio        npx prisma studio
  format        npx prisma format
  validate      npx prisma validate

  sweep         sweeper ExecutionLog SUBMITTED/PENDING (mock on-chain)

  env           suggerisce copia .env (non sovrascrive file esistenti)
  help          questa guida

Esempi:
  ./afx install && ./afx migrate && ./afx dev
  ./afx dev-clean    # dopo errori tipo Cannot find module './NNN.js'
EOF
}

free_port_3001() {
  local p
  p=$(lsof -ti:3001 2>/dev/null || true)
  if [[ -n "${p:-}" ]]; then
    echo "afx: termino processo su :3001 (pid $p)"
    kill "$p" 2>/dev/null || true
    sleep 0.5
  fi
}

ensure_env_hint() {
  if [[ ! -f "$ROOT/.env" ]]; then
    echo "afx: manca .env — esegui: cp .env.example .env && modifica DATABASE_URL" >&2
    exit 1
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  install)
    npm install
    ;;
  dev)
    npm run dev
    ;;
  clean)
    rm -rf "$ROOT/apps/web/.next" "$ROOT/.next" 2>/dev/null || true
    echo "afx: cache Next (.next) rimossa."
    ;;
  dev-clean)
    rm -rf "$ROOT/apps/web/.next" "$ROOT/.next" 2>/dev/null || true
    echo "afx: cache Next (.next) rimossa."
    free_port_3001
    npm run dev
    ;;
  build)
    npm run build
    ;;
  start)
    npm run start
    ;;
  lint)
    npm run lint
    ;;
  prisma-gen)
    npm run prisma:generate
    ;;
  migrate)
    ensure_env_hint
    npm run prisma:migrate -- "$@"
    ;;
  deploy)
    ensure_env_hint
    npx prisma migrate deploy "$@"
    ;;
  studio)
    ensure_env_hint
    npm run prisma:studio -- "$@"
    ;;
  format)
    npm run prisma:format
    ;;
  validate)
    npx prisma validate "$@"
    ;;
  sweep)
    ensure_env_hint
    npm run sweep -- "$@"
    ;;
  env)
    if [[ ! -f "$ROOT/.env" ]]; then
      cp -n "$ROOT/.env.example" "$ROOT/.env" && echo "Creato .env da .env.example"
    else
      echo ".env già presente, non toccato."
    fi
    if [[ ! -f "$ROOT/apps/web/.env.local" ]]; then
      if [[ -f "$ROOT/apps/web/env.local.template" ]]; then
        cp -n "$ROOT/apps/web/env.local.template" "$ROOT/apps/web/.env.local" && echo "Creato apps/web/.env.local da env.local.template"
      fi
    else
      echo "apps/web/.env.local già presente, non toccato."
    fi
    echo "Modifica DATABASE_URL in .env e in apps/web/.env.local se serve."
    ;;
  *)
    echo "afx: comando sconosciuto: $cmd" >&2
    echo "Usa: ./afx help" >&2
    exit 1
    ;;
esac
