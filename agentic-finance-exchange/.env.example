# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/afx_dev?schema=public"

# Anthropic (API chat — apps/web)
ANTHROPIC_API_KEY=

# Modello opzionale (default: claude-sonnet-4-20250514)
AFX_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Wallet di default per /api/chat se il client non invia walletAddress (solo dev)
AFX_CHAT_DEFAULT_WALLET=0x0000000000000000000000000000000000000afb

# Riferimento KMS mock (signer)
AFX_KMS_KEY_REF=mock-kms-afx-001
