# Arbitrum Sepolia: 0x101F443B4d1b059569D643917553c771E1b9663E (NON 0x68b346… su Sepolia!)
# Ethereum / Arbitrum One: 0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
# Anvil local mock: 0xe7f1725e7734ce288f8367e1bb143e90bb3f0512
AFX_DEX_ROUTER_ADDRESS=0x101F443B4d1b059569D643917553c771E1b9663E
# Mercato primario RWA testnet (MockRwaPrimary — output deploy forge)
# AFX_RWA_PRIMARY_ADDRESS=0x...
# AFX_RWA_MQQQ_ADDRESS=0x...
# AFX_RWA_MGLD_ADDRESS=0x...
# Keeper Phase 3 — chiave EOA MANAGER (solo dev Anvil account #1, mai in prod git)
# MANAGER_PRIVATE_KEY=0xac0974bec39a17e36ba4b6a2d5ba4c7c2ff80cc47797b43987550c256d9b1a12
# Keeper: sizing obbligatorio in ExecutionLog.payloadJson.sizing (da proposeExecution).
# amountOutMinimum calcolato via Uniswap QuoterV2 + slippage 0.5% (nessun fallback importo).
AFX_SIGNER_MODE=mock
AFX_KMS_PROVIDER=aws-kms
AFX_KMS_REGION=eu-central-1
AFX_KMS_KEY_REF=mock-kms-afx-001
# sweeper: mock = hash fittizi | real = MANAGER chiama SmartVault.executeTrade on-chain
AFX_ONCHAIN_CONFIRM_MODE=mock
# npm run seed:web3  — whitelist router in DB prima del keeper real
