# Log token cache in console: AFX_LOG_PROMPT_CACHE=true
AFX_CHAT_DEFAULT_WALLET=0x0000000000000000000000000000000000000afb
NEXT_PUBLIC_AFX_DEFAULT_WALLET=0x0000000000000000000000000000000000000afb
#
# Phase C / Web3 MVP (Foundry deploy → incolla indirizzi qui)
