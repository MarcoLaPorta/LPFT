# Consumer intent LPFT→Prisma (`npm run worker:intents`) — stesso Redis dell’API
LPFT_REDIS_URL=redis://localhost:6379/0
# Deve coincidere con LPFT_AFX_INTENTS_CHANNEL in services/api/.env.local
AFX_INTENTS_CHANNEL=afx:intents:new
# Wallet utente Prisma se il payload non porta wallet_address (default: utente ponte migrazione)
AFX_INTENT_DEFAULT_WALLET=0x0000000000000000000000000000000000000001
