# Opzionale: base interna server-side (proxy tier1-validate)
# LPFT_API_INTERNAL_BASE=http://127.0.0.1:8000
#
# PostgreSQL AFX (Prisma) — stesso host possibile, DB logico separato consigliato (es. afx_dev)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/afx_dev?schema=public
