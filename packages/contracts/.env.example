# Copia in packages/contracts/.env (non committare)
# Deployer — deve avere ETH su Arbitrum Sepolia (faucet: https://faucet.quicknode.com/arbitrum/sepolia)
PRIVATE_KEY=0x...

# Keeper EOA (può coincidere con deployer in test)
MANAGER_ADDRESS=0x...

# RPC (Alchemy/Infura/QuickNode o pubblico)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Opzionale — verify contratti su Arbiscan
ARBISCAN_API_KEY=

# setup-sepolia-liquidity.sh (deposit)
# VAULT_ADDRESS=0x...          # clone SmartVault dell'OWNER
# VAULT_FACTORY_ADDRESS=0x...
# OWNER_PRIVATE_KEY=0x...      # default: PRIVATE_KEY
# DEPOSIT_USDC_AMOUNT=1000000  # 1 USDC (6 dec)
